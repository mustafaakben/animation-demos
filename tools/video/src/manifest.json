      "durationInFrames": 1136,
      "segments": [
        {
          "lineId": "s10b_01",
          "who": "narrator",
          "name": "NARRATOR",
          "role": "",
          "portrait": null,
          "text": "College Coffee. The Commons smells like cinnamon and cut grass. The provost reads a headline that promises exactly what the study delivered — no more, no less.",
          "shot": "kenburns",
          "from": 24,
          "audioFrames": 430,
          "durationInFrames": 444
        },
        {
          "lineId": "s10b_02",
          "who": "jordan",
          "name": "Jordan Okafor",
          "role": "Junior · Lead Researcher, CalmCampus Study",
          "portrait": "jordan.jpg",
          "text": "You wrote “shows promise” and put our limitations in paragraph two. Do you know what happens when researchers trust the comms office? Nothing! Nothing happens! It’s amazing. Thank you.",
          "shot": "talkingCard",
          "from": 468,
          "audioFrames": 449,
          "durationInFrames": 463
        },
        {
          "lineId": "s10b_03",
          "who": "maya",
          "name": "Maya Torres",
          "role": "Associate Director, University Communications",
          "portrait": "maya.jpg",
          "text": "Slower than I wanted. Better than I hoped. That trade usually goes the other way.",
          "shot": "talkingCard",
          "from": 931,
          "audioFrames": 155,
          "durationInFrames": 169
        }
      ]
